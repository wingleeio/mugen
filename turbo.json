{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DISABLE_PRERENDER", "DISABLE_NITRO"],
      "outputs": [
        "dist/**",
        "build/**",
        ".output/**",
        ".nitro/**",
        ".vercel/**",
        ".source/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
