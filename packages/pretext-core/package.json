{
  "name": "@wingleeio/pretext-core",
  "version": "0.1.4",
  "description": "C++ JSI text engine for React Native — @chenglou/pretext's line breaker and pretext-native's font-table metrics, ported to native and exposed as synchronous JSI calls, plus the PretextBlockView single-view text block.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wingleeio/mugen.git",
    "directory": "packages/pretext-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": {
        "import": "./dist/index.native.js",
        "require": "./dist/index.native.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./text-block": {
      "types": "./dist/text-block.d.ts",
      "react-native": {
        "import": "./dist/text-block.native.js",
        "require": "./dist/text-block.native.cjs"
      },
      "import": "./dist/text-block.js",
      "require": "./dist/text-block.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "cpp",
    "ios",
    "android",
    "nitrogen/generated",
    "*.podspec",
    "nitro.json"
  ],
  "scripts": {
    "build": "tsdown && node scripts/fix-metro-require.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "gen:tables": "node scripts/gen-unicode-tables.mjs",
    "build:host": "cmake -S . -B build-host -DCMAKE_BUILD_TYPE=Release && cmake --build build-host -j",
    "clean": "rm -rf dist build-host"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.8",
    "@wingleeio/pretext-native": "workspace:^"
  },
  "devDependencies": {
    "@chenglou/pretext": "0.0.8",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.17",
    "@wingleeio/pretext-native": "workspace:^",
    "nitrogen": "0.36.1",
    "react-native": "0.81.5",
    "react-native-nitro-modules": "0.36.1",
    "tsdown": "^0.15.7",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76",
    "react-native-nitro-modules": ">=0.26.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-nitro-modules": {
      "optional": true
    }
  }
}
