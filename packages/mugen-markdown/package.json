{
  "name": "@wingleeio/mugen-markdown",
  "version": "0.2.0",
  "description": "Measurable markdown for mugen — incremark-parsed, rendered with mugen primitives so the virtualizer's tree walker computes exact row heights.",
  "license": "MIT",
  "author": "Wing Lee <contact@winglee.io>",
  "homepage": "https://mugen.winglee.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wingleeio/mugen.git",
    "directory": "packages/mugen-markdown"
  },
  "bugs": "https://github.com/wingleeio/mugen/issues",
  "keywords": [
    "react",
    "markdown",
    "incremental",
    "streaming",
    "virtualization",
    "mugen",
    "gfm"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@incremark/core": "^1.0.2",
    "@chenglou/pretext": "0.0.7",
    "@types/mdast": "^4.0.4"
  },
  "peerDependencies": {
    "@wingleeio/mugen": ">=0.3.0 <1.0.0",
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@wingleeio/mugen": "workspace:*",
    "happy-dom": "^20.10.1",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
