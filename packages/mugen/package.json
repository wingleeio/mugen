{
  "name": "@wingleeio/mugen",
  "version": "0.3.6",
  "description": "Virtualized React lists with analytic row heights — measured with pretext, never the DOM.",
  "license": "MIT",
  "author": "Wing Lee <contact@winglee.io>",
  "homepage": "https://mugen.winglee.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wingleeio/mugen.git",
    "directory": "packages/mugen"
  },
  "bugs": "https://github.com/wingleeio/mugen/issues",
  "keywords": [
    "react",
    "virtualization",
    "virtual-list",
    "virtual-scroll",
    "infinite-scroll",
    "chat",
    "ai",
    "streaming",
    "text-measurement",
    "stick-to-bottom"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.7",
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "happy-dom": "^20.10.1",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
