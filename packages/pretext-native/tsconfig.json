{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // Deliberately NO "DOM" lib: this package must compile against pure
    // ECMAScript to prove it never leans on browser globals — that's the whole
    // point of a React Native / Hermes backend. Anything global we touch
    // (OffscreenCanvas installation) goes through narrow local casts.
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "outDir": "dist"
  },
  "include": ["src", "tsdown.config.ts", "vitest.config.ts"]
}
