{
  "name": "@wingleeio/mugen-native",
  "version": "0.9.0",
  "description": "React Native renderer for mugen — virtualized lists with analytic row heights, measured with pretext-native, never the host layout.",
  "license": "MIT",
  "author": "Wing Lee <contact@winglee.io>",
  "homepage": "https://mugen.winglee.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wingleeio/mugen.git",
    "directory": "packages/mugen-native"
  },
  "bugs": "https://github.com/wingleeio/mugen/issues",
  "keywords": [
    "react-native",
    "virtualization",
    "virtual-list",
    "virtual-scroll",
    "infinite-scroll",
    "chat",
    "ai",
    "streaming",
    "text-measurement",
    "stick-to-bottom",
    "mugen"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.8",
    "@wingleeio/mugen": "workspace:^",
    "@wingleeio/pretext-native": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-test-renderer": "^19.1.0",
    "react": "^19.2.6",
    "react-native": "^0.81.0",
    "react-test-renderer": "^19.2.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
